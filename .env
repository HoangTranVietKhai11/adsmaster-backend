# ─────────────────────────────────────────────
# AdsMaster-AI-SaaS — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in values

# ─── App ──────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://adsmaster:secret@localhost:5432/adsmaster_db
POSTGRES_USER=adsmaster
POSTGRES_PASSWORD=secret
POSTGRES_DB=adsmaster_db

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=your-very-long-access-secret-here
JWT_REFRESH_SECRET=your-very-long-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ─── AWS S3 ───────────────────────────────────
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=adsmaster-ai-saas

# ─── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@adsmaster.ai

# ─── AI Engine ────────────────────────────────
AI_ENGINE_URL=http://ai-engine:8000

# ─── Affiliate ────────────────────────────────
AFFILIATE_COMMISSION_RATE=0.30
